; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Programming Demo"
run/main_scene="uid://b0x7uiinmtg7b"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

Utils="*res://scripts/utils.gd"
World="*res://scripts/world.gd"

[display]

window/size/viewport_height=640
window/stretch/mode="viewport"

[global_group]

Enemies="Entites that would damage the Player"

[gui]

theme/default_font_multichannel_signed_distance_field=true
theme/default_font_generate_mipmaps=true

[internationalization]

rendering/text_driver="ICU / HarfBuzz / Graphite (Built-in)"

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

textures/canvas_textures/default_texture_filter=0
rendering_device/driver.windows="d3d12"
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/default_filters/use_nearest_mipmap_filter=true
viewport/hdr_2d=true
environment/defaults/default_clear_color=Color(0.7882353, 0.49411765, 0.32156864, 1)
